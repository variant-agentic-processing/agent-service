GCP_PROJECT=variant-processing
GCP_REGION=us-central1

# MCP server URL (Cloud Run internal URL)
MCP_SERVER_URL=https://mcp-variant-server-fno64g2krq-uc.a.run.app

# Anthropic API key — fetched from Secret Manager at runtime if not set here
# ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: override OIDC identity token for local dev against live MCP server
# Run: gcloud auth print-identity-token --audiences=https://mcp-variant-server-fno64g2krq-uc.a.run.app
# MCP_IDENTITY_TOKEN=<token>

# Agent service URL for poe ask (defaults to http://localhost:8080)
# AGENT_SERVICE_URL=https://agent-service-fno64g2krq-uc.a.run.app

# Pulumi passphrase file — same as infra/
PULUMI_CONFIG_PASSPHRASE_FILE=/Users/ryan/.pulumi/variant-processing-passphrase

# Docker image tag (used by poe build)
IMAGE_TAG=latest
